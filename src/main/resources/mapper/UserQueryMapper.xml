<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.team2.auth.query.mapper.UserQueryMapper">

    <resultMap id="departmentResultMap" type="com.team2.auth.command.domain.entity.Department">
        <id property="departmentId" column="department_id"/>
        <result property="departmentName" column="department_name"/>
        <result property="createdAt" column="dept_created_at"/>
    </resultMap>

    <resultMap id="teamResultMap" type="com.team2.auth.command.domain.entity.Team">
        <id property="teamId" column="team_id"/>
        <result property="teamName" column="team_name"/>
        <result property="createdAt" column="team_created_at"/>
        <association property="department" resultMap="departmentResultMap"/>
    </resultMap>

    <resultMap id="positionResultMap" type="com.team2.auth.command.domain.entity.Position">
        <id property="positionId" column="position_id"/>
        <result property="positionName" column="position_name"/>
        <result property="positionLevel" column="position_level"/>
        <result property="createdAt" column="pos_created_at"/>
    </resultMap>

    <resultMap id="userResultMap" type="com.team2.auth.command.domain.entity.User">
        <id property="userId" column="user_id"/>
        <result property="employeeNo" column="employee_no"/>
        <result property="userName" column="user_name"/>
        <result property="userEmail" column="user_email"/>
        <result property="userPw" column="user_pw"/>
        <result property="userRole" column="user_role" typeHandler="com.team2.auth.config.RoleTypeHandler"/>
        <result property="userStatus" column="user_status" typeHandler="com.team2.auth.config.UserStatusTypeHandler"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <association property="team" resultMap="teamResultMap"/>
        <association property="position" resultMap="positionResultMap"/>
    </resultMap>

    <sql id="userColumns">
        u.user_id,
        u.employee_no,
        u.user_name,
        u.user_email,
        u.user_pw,
        u.user_role,
        u.user_status,
        u.created_at,
        u.updated_at,
        t.team_id,
        t.team_name,
        t.created_at AS team_created_at,
        d.department_id,
        d.department_name,
        d.created_at AS dept_created_at,
        p.position_id,
        p.position_name,
        p.position_level,
        p.created_at AS pos_created_at
    </sql>

    <sql id="userJoins">
        FROM users u
        LEFT JOIN teams t ON u.team_id = t.team_id
        LEFT JOIN departments d ON t.department_id = d.department_id
        LEFT JOIN positions p ON u.position_id = p.position_id
    </sql>

    <select id="findById" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        <include refid="userJoins"/>
        WHERE u.user_id = #{userId}
    </select>

    <select id="findByUserEmail" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        <include refid="userJoins"/>
        WHERE u.user_email = #{userEmail}
    </select>

    <select id="findByEmployeeNo" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        <include refid="userJoins"/>
        WHERE u.employee_no = #{employeeNo}
    </select>

    <select id="findAll" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        <include refid="userJoins"/>
        ORDER BY u.user_id
    </select>

    <select id="findByTeamId" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        <include refid="userJoins"/>
        WHERE u.team_id = #{teamId}
        ORDER BY u.user_id
    </select>

    <select id="findByDepartmentId" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        <include refid="userJoins"/>
        WHERE t.department_id = #{departmentId}
        ORDER BY u.user_id
    </select>

    <select id="findByUserStatus" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        <include refid="userJoins"/>
        WHERE u.user_status = #{userStatus}
        ORDER BY u.user_id
    </select>

    <sql id="userListColumns">
        u.user_id       AS userId,
        u.employee_no   AS employeeNo,
        u.user_name     AS userName,
        u.user_email    AS userEmail,
        u.user_role     AS userRole,
        u.user_status   AS userStatus,
        u.created_at    AS createdAt,
        t.team_id       AS teamId,
        t.team_name     AS teamName,
        d.department_id AS departmentId,
        d.department_name AS departmentName,
        p.position_name AS positionName
    </sql>

    <sql id="userFilterConditions">
        <where>
            <if test="userName != null and userName != ''">
                AND u.user_name LIKE CONCAT('%', #{userName}, '%')
            </if>
            <if test="teamId != null">
                AND u.team_id = #{teamId}
            </if>
            <if test="departmentId != null">
                AND t.department_id = #{departmentId}
            </if>
            <if test="userRole != null and userRole != ''">
                AND u.user_role = #{userRole}
            </if>
            <if test="userStatus != null and userStatus != ''">
                AND u.user_status = #{userStatus}
            </if>
        </where>
    </sql>

    <select id="findByCondition" resultType="com.team2.auth.query.dto.UserListResponse">
        SELECT
        <include refid="userListColumns"/>
        <include refid="userJoins"/>
        <include refid="userFilterConditions"/>
        ORDER BY u.user_id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*)
        FROM users u
        LEFT JOIN teams t ON u.team_id = t.team_id
        <include refid="userFilterConditions"/>
    </select>

    <select id="findApprovers" resultType="com.team2.auth.query.dto.UserListResponse">
        SELECT
        <include refid="userListColumns"/>
        <include refid="userJoins"/>
        WHERE u.user_status = 'active'
          AND (
            u.user_role = 'admin'
            <if test="teamId != null">
                OR (u.team_id = #{teamId} AND p.position_level = 1)
            </if>
            <if test="teamId == null">
                OR p.position_level = 1
            </if>
          )
        ORDER BY u.user_role = 'admin' DESC, u.user_name ASC
    </select>

    <select id="existsByUserEmail" resultType="int">
        SELECT COUNT(*) FROM users WHERE user_email = #{userEmail}
    </select>

    <select id="existsByEmployeeNo" resultType="int">
        SELECT COUNT(*) FROM users WHERE employee_no = #{employeeNo}
    </select>

    <select id="findUserIdsByTeam" resultType="java.lang.Integer">
        SELECT user_id
          FROM users
         WHERE team_id = #{teamId}
           AND user_status = 'active'
         ORDER BY user_id
    </select>

</mapper>
